{
  "name": "apphub",
  "version": "4.0.10",
  "description": "Cloudflare Pages portal hub. Static landing + PWA dispatcher routing visitors to a configurable set of sub-applications via a card-grid UI, backed by Cloudflare D1.",
  "license": "AGPL-3.0-or-later",
  "author": "Leonardo Cardozo Vargas (lcv-leo)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lcv-leo/apphub.git"
  },
  "homepage": "https://github.com/lcv-leo/apphub#readme",
  "bugs": {
    "url": "https://github.com/lcv-leo/apphub/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "format": "biome format --write src",
    "lint": "biome check src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "undici": "6.24.0",
    "vite": "$vite",
    "postcss": "8.5.10"
  }
}
